# ─────────────────────────────────────────────────────────────
# ARPA Micro Series: F1 Mask — .env.example
# Copy to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# Phase 2: Synthetic Generation (Gemini API)
GEMINI_API_KEY=your-gemini-api-key-here

# Phase 5: Middleware Bridge (Ollama Connection)
OLLAMA_URL=http://localhost:11434/api/chat
F1_MASK_MODEL=arpacorp/micro-f1-mask

# Phase 5: Redis Vault
REDIS_HOST=localhost
REDIS_PORT=6379

# Phase 5: Cloud LLM Connection (Forwarding)
CLOUD_LLM_URL=https://api.openai.com/v1/chat/completions
CLOUD_API_KEY=sk-your-openai-api-key-here
